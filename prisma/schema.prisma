// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("customer") // "customer" | "admin"
  addresses String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders   Order[]
  bookings Booking[]
  reviews  Review[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  price         Float
  originalPrice Float?
  discount      Int?
  category      String   // "suits" | "sarees" | "blouses"
  images        String[] @default([])
  fabric        String
  color         String
  occasion      String
  sizes         String[] @default([])
  description   String
  washCare      String
  stock         Int      @default(0)
  featured      Boolean  @default(false)
  newArrival    Boolean  @default(false)
  rating        Float    @default(5.0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews    Review[]
  orderItems OrderItem[]
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  userName  String
  createdAt DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?
}

model TailoringService {
  id            String   @id @default(cuid())
  name          String
  category      String   // "stitching" | "alteration" | "finishing"
  description   String
  startingPrice Float
  duration      String
  image         String?
  createdAt     DateTime @default(now())

  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  customerName  String
  phone         String
  preferredDate String
  preferredTime String
  notes         String?
  status        String   @default("pending") // "pending" | "accepted" | "completed" | "rejected"
  createdAt     DateTime @default(now())

  service   TailoringService @relation(fields: [serviceId], references: [id])
  serviceId String

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  email           String
  phone           String
  shippingAddress String
  billingAddress  String
  subtotal        Float
  tax             Float
  shipping        Float
  total           Float
  paymentMethod   String
  status          String      @default("pending") // "pending" | "packed" | "shipped" | "delivered" | "cancelled"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items  OrderItem[]
  user   User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?
}

model OrderItem {
  id          String  @id @default(cuid())
  productName String
  image       String
  price       Float
  quantity    Int
  size        String

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId String?
}

model Coupon {
  id        String   @id @default(cuid())
  code      String   @unique
  discount  Float
  type      String   // "percentage" | "fixed"
  minOrder  Float    @default(0)
  maxUses   Int      @default(100)
  usedCount Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
